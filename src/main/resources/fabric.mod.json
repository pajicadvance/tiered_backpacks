{
  "schemaVersion": 1,
  "id": "tiered_backpacks",
  "version": "${version}",
  "name": "Tiered Backpacks",
  "description": "Simple tiered backpacks with Accessories support",
  "authors": ["pajic", "Moonkey"],
  "contact": {},
  "license": "MIT",
  "icon": "icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      "me.pajic.tiered_backpacks.ClientMain"
    ],
    "main": [
      "me.pajic.tiered_backpacks.Main"
    ],
    "shulkerboxtooltip": [
      "me.pajic.tiered_backpacks.tooltip.BackpackTooltipCompat"
    ]
  },
  "mixins": [
    "tiered_backpacks.mixins.json"
  ],
  "accessWidener": "tiered_backpacks.accesswidener",
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": "${minecraft_version}",
    "fzzy_config": "*"
  }
}
